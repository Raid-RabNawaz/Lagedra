            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{adminToken}}", "type": "string" }]
            },
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"California (Updated)\",\n  \"rules\": {\n    \"maxSecurityDeposit\": 1,\n    \"noticePeriodDays\": 60,\n    \"requiresRentersInsurance\": true\n  }\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/admin/jurisdictions/US-CA", "host": ["{{baseUrl}}"], "path": ["api", "admin", "jurisdictions", "US-CA"] }
          }
