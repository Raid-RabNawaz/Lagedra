          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Modern 2BR in Downtown\",\n  \"description\": \"Fully furnished apartment with city views.\",\n  \"propertyType\": \"Apartment\",\n  \"bedrooms\": 2,\n  \"bathrooms\": 1,\n  \"monthlyRent\": 2500.00,\n  \"currency\": \"USD\",\n  \"address\": {\n    \"street\": \"123 Main St\",\n    \"city\": \"Austin\",\n    \"state\": \"TX\",\n    \"zipCode\": \"78701\",\n    \"country\": \"US\"\n  },\n  \"minimumStayMonths\": 3,\n  \"maximumStayMonths\": 12\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/listings", "host": ["{{baseUrl}}"], "path": ["api", "listings"] }
          }
        },
        {
          "name": "Update Listing",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Updated 2BR in Downtown\",\n  \"monthlyRent\": 2700.00\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/listings/{{listingId}}", "host": ["{{baseUrl}}"], "path": ["api", "listings", "{{listingId}}"] }
          }
        },
        {
          "name": "Publish Listing",
          "request": {
            "method": "POST",
            "url": { "raw": "{{baseUrl}}/api/listings/{{listingId}}/publish", "host": ["{{baseUrl}}"], "path": ["api", "listings", "{{listingId}}", "publish"] }
          }
        },
