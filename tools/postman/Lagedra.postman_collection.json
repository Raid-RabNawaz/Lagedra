          }
        },
        {
          "name": "Create Jurisdiction Pack (Admin)",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{adminToken}}", "type": "string" }]
            },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"code\": \"US-CA\",\n  \"name\": \"California\",\n  \"country\": \"US\",\n  \"state\": \"CA\",\n  \"rules\": {\n    \"maxSecurityDeposit\": 2,\n    \"noticePeriodDays\": 30,\n    \"requiresRentersInsurance\": true\n  }\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/admin/jurisdictions", "host": ["{{baseUrl}}"], "path": ["api", "admin", "jurisdictions"] }
          }
        },
