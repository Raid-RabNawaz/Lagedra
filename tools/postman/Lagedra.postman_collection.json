          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/listings?city=Austin&minRent=1000&maxRent=3000&page=1&pageSize=20",
              "host": ["{{baseUrl}}"],
              "path": ["api", "listings"],
              "query": [
                { "key": "city", "value": "Austin" },
                { "key": "minRent", "value": "1000" },
                { "key": "maxRent", "value": "3000" },
                { "key": "page", "value": "1" },
                { "key": "pageSize", "value": "20" }
